# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3003
LOG_LEVEL=debug

# ─── MongoDB ─────────────────────────────────────────
MONGODB_URI=mongodb://ifarm:ifarm123@localhost:27017/ifarm_catalog

# ─── RabbitMQ ────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 ──────────────────────────────────────────
S3_BUCKET=ifarm-catalog-images
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
