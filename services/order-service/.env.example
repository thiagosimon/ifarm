# ─── Server ─────────────────────────────────────────
PORT=3006
NODE_ENV=development

# ─── PostgreSQL ────────────────────────────────────
POSTGRES_URI=postgres://ifarm:ifarm@localhost:5432/ifarm_orders

# ─── RabbitMQ ──────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Payment Service ──────────────────────────────
PAYMENT_SERVICE_URL=http://localhost:3007

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=debug
