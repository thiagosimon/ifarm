# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── MongoDB ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ifarm_identity

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Encryption (AES-256-GCM) ───────────────────────
# 32-byte key, base64 encoded
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ─── RabbitMQ ────────────────────────────────────────
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# ─── AWS S3 ──────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_S3_BUCKET=ifarm-identity-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PRESIGNED_URL_TTL_SECONDS=900

# ─── Serpro ──────────────────────────────────────────
SERPRO_BASE_URL=https://gateway.apiserpro.serpro.gov.br
SERPRO_CLIENT_ID=
SERPRO_CLIENT_SECRET=
SERPRO_TOKEN_URL=https://gateway.apiserpro.serpro.gov.br/token
SERPRO_CACHE_TTL_SECONDS=86400
SERPRO_TIMEOUT_MS=5000
SERPRO_MAX_RETRIES=2

# ─── Keycloak (external auth) ───────────────────────
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=ifarm
