# ─── Server ─────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ifarm_quotation

# ─── Redis / BullMQ ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── RabbitMQ ───────────────────────────────────────
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# ─── Tax Service ────────────────────────────────────
TAX_SERVICE_URL=http://localhost:3009

# ─── Quote defaults ────────────────────────────────
QUOTE_EXPIRATION_HOURS=24

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=debug
