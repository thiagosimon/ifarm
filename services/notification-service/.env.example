# --- Server --------------------------------------------------
NODE_ENV=development
PORT=3010
LOG_LEVEL=debug

# --- MongoDB -------------------------------------------------
MONGODB_URI=mongodb://ifarm:ifarm123@localhost:27017/ifarm_notification

# --- RabbitMQ ------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- Redis ---------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- OneSignal (Push) ----------------------------------------
