# ─────────────────────────────────────────────────────────────────────────────
# iFarm Production Environment — Mac Mini
# Copie este arquivo para .env.prod e preencha todos os valores
# NUNCA commite .env.prod no git
# ─────────────────────────────────────────────────────────────────────────────

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.ifarm.agr.br,https://admin.ifarm.agr.br,https://carbon.ifarm.agr.br,https://saas.ifarm.agr.br

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=ifarm
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_password_here

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ifarm
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password_here

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=ifarm
RABBITMQ_PASSWORD=CHANGE_ME_strong_password_here

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_HOSTNAME=auth.ifarm.agr.br
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
KEYCLOAK_CLIENT_ID=ifarm-api
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_generate_with_keycloak_admin

# ─── Identity Service — Criptografia (RSD-001) ────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
IDENTITY_ENCRYPTION_KEY=

# ─── AWS (S3 para documentos KYC + SES para e-mail) ─────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_IDENTITY=ifarm-identity-documents-prod

# ─── Serpro (validação CPF/CNPJ) ─────────────────────────────────────────────
SERPRO_BASE_URL=https://gateway.apiserpro.serpro.gov.br
SERPRO_TOKEN_URL=https://gateway.apiserpro.serpro.gov.br/token
SERPRO_CLIENT_ID=
SERPRO_CLIENT_SECRET=

# ─── Pagar.me v5 ──────────────────────────────────────────────────────────────
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# ─── OneSignal (push notifications) ──────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ─── Meta Cloud API (WhatsApp) ────────────────────────────────────────────────
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
