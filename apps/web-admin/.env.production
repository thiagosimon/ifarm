# ─── Web Admin Production Environment ────────────────────────────────────────
# Public vars (embedded in JS bundle)
NEXT_PUBLIC_API_URL=https://api.ifarm.agr.br/api

# Keycloak OAuth
KEYCLOAK_ISSUER=https://auth.ifarm.agr.br/realms/ifarm
KEYCLOAK_CLIENT_ID=ifarm-web-admin

# KEYCLOAK_CLIENT_SECRET and NEXTAUTH_SECRET must be set in Netlify/Vercel dashboard
