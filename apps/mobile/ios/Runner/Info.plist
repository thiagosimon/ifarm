<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>pt_BR</string>
	<key>CFBundleDisplayName</key>
	<string>iFarm</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>iFarm</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Camera — KYC document capture -->
	<key>NSCameraUsageDescription</key>
	<string>O iFarm precisa acessar a câmera para capturar fotos de documentos KYC e da propriedade rural.</string>

	<!-- Photo Library — image_picker -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>O iFarm precisa acessar sua galeria de fotos para enviar documentos e imagens da propriedade.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>O iFarm pode salvar fotos da propriedade na sua galeria.</string>

	<!-- Location — GPS da propriedade -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>O iFarm usa sua localização para registrar as coordenadas GPS da propriedade rural.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>O iFarm usa sua localização para registrar as coordenadas GPS da propriedade rural.</string>

	<!-- Face ID / Biometria -->
	<key>NSFaceIDUsageDescription</key>
	<string>Use o Face ID para acessar o iFarm com segurança.</string>

	<!-- Microphone (opcional — future video KYC) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>O iFarm pode usar o microfone para gravação de vídeo KYC.</string>

	<!-- URL Schemes — deep links -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>br.com.ifarm.mobile</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ifarm</string>
			</array>
		</dict>
	</array>

	<!-- App Transport Security — HTTPS only -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>api.ifarm.com.br</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
