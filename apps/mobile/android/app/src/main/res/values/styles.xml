<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- iFarm launch theme — green canopy background while Flutter initializes -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">#1A6B3C</item>
        <item name="android:navigationBarColor">#1A6B3C</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <!-- Normal theme applied after Flutter renders its first frame -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
